# Hermes Scale — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# Postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=15432

# Redis
REDIS_PORT=6379

# Gateway
GATEWAY_PORT=8443

# Workers (default 4, scale up for more concurrent users)
WORKER_REPLICAS=4

# OpenRouter API key (used as default for new tenants)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
