# ============================================================
# AI Employee Control Plane — Required Environment Variables
# Copy to /opt/hermes-control-plane/.env and fill in values
# ============================================================

# Control Plane
PAYPAL_WEBHOOK_ID=        # From PayPal developer dashboard > Webhooks
TELEGRAM_BOT_TOKEN=       # From @BotFather — for control plane notifications
TELEGRAM_OWNER_ID=        # Your Telegram numeric user ID (use @userinfobot)
CONTROL_PLANE_PORT=8080
CONTROL_PLANE_URL=        # https://yourdomain.com (no trailing slash)

# DigitalOcean VM Provisioning
DO_API_TOKEN=             # DigitalOcean API token (read+write)
DO_SSH_KEY_ID=            # SSH key fingerprint in DO account
DO_REGION=nyc3            # DO datacenter region

# Voice (Vapi.ai)
VAPI_API_KEY=             # Vapi private key
VAPI_WEBHOOK_SECRET=      # Secret from ~/.hermes/.webhook_secret

# Avatar (HeyGen)
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=         # Avatar template ID in HeyGen dashboard
HEYGEN_VOICE_ID=          # Voice ID

# SMS + WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=           # E.164 format: +14155551234
TWILIO_WHATSAPP_NUMBER=       # whatsapp:+14155551234 (WhatsApp-enabled Twilio number)

# Appointment Booking (Cal.com — open source Calendly)
CALCOM_API_KEY=               # From cal.com/settings/developer/api-keys
CALCOM_EVENT_ID=              # Numeric event type ID from cal.com/event-types
CALCOM_BASE_URL=              # Only for self-hosted Cal.com; omit to use cal.com

# Invoicing & Quotes (Crater — open source invoicing)
CRATER_BASE_URL=              # https://invoice.yourdomain.com (self-hosted Crater URL)
CRATER_API_TOKEN=             # Profile → API Tokens in Crater dashboard
CRATER_COMPANY_ID=            # Numeric company ID from Crater URL when logged in

# Email Marketing (Mautic — open source Mailchimp)
MAUTIC_BASE_URL=              # https://mail.yourdomain.com (self-hosted Mautic URL)
MAUTIC_USERNAME=              # Mautic admin username
MAUTIC_PASSWORD=              # Mautic admin password

# ── Zero-cost self-hosted alternatives ─────────────────────────────────────

# WhatsApp via Evolution API (replaces Twilio WhatsApp — free)
# docker run -d -p 8080:8080 atendai/evolution-api:latest
EVOLUTION_API_URL=            # http://your-server:8080
EVOLUTION_API_KEY=            # API key set in Evolution API config (self-generated)
EVOLUTION_INSTANCE=default    # Instance name (scan QR once to connect)

# Voice/Phone via Fonoster (replaces Vapi — free, self-hosted)
# https://github.com/fonoster/fonoster
FONOSTER_ACCESS_KEY_ID=       # From Fonoster dashboard → API Keys
FONOSTER_ACCESS_KEY_SECRET=   # From Fonoster dashboard → API Keys
FONOSTER_APP_REF=             # Voice application reference
FONOSTER_FROM_NUMBER=         # E.164 caller ID number
FONOSTER_API_URL=             # Only for self-hosted; omit to use api.fonoster.io

# SMS via Android phone (replaces Twilio SMS — free)
# Install app: https://github.com/capcom6/android-sms-gateway
ANDROID_SMS_GATEWAY_URL=      # http://phone-ip:8080
ANDROID_SMS_GATEWAY_USER=user
ANDROID_SMS_GATEWAY_PASSWORD= # Password set in the Android app

# Appointment booking via Easy!Appointments (replaces Cal.com — free)
# docker run -d -p 8080:80 alextselegidis/easyappointments
EASYAPP_URL=                  # http://your-server:8080
EASYAPP_USERNAME=             # Admin username
EASYAPP_PASSWORD=             # Admin password

# AI (Anthropic — injected into each customer VM)
CLAUDE_CODE_OAUTH_TOKEN=      # Anthropic API key
